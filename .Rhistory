# 1. Definición de periodos
is_25 <- (!is.na(df$year) & df$year == "2025")
is_retra <- (!is.na(df$year) & df$year != "2025")
# ---------------------------------------------------------
# 1.5. PREPARACIÓN DE DATOS (El truco para que funcione)
# ---------------------------------------------------------
# Transfusión: Si está vacío (NA) o es 0, es "no". Cualquier otro número es "si".
df$transf_dico <- ifelse(is.na(df$hematies_concentrado) | df$hematies_concentrado == 0, "no", "si")
# Traqueotomía: Agrupamos las quirúrgicas y percutáneas en un "si" general. El resto "no".
df$traqueo_dico <- ifelse(df$traqueotomia %in% c("percutanea", "quirurgica"), "si", "no")
# ---------------------------------------------------------
# Función auxiliar para formatear porcentajes
fmt_pct <- function(p) {
val <- sprintf("%.1f", p)
val <- gsub("\\.", ",", val)
val <- sub(",0$", "", val)
return(val)
}
# 2. Función categórica
calc_cat <- function(var_col, cat_val, label) {
col_data <- as.character(df[[var_col]])
cat_val_char <- as.character(cat_val)
tot_r <- sum(!is.na(col_data) & col_data != "" & is_retra)
tot_2 <- sum(!is.na(col_data) & col_data != "" & is_25)
c_r <- sum(col_data == cat_val_char & is_retra, na.rm = TRUE)
c_2 <- sum(col_data == cat_val_char & is_25, na.rm = TRUE)
pct_r <- if(tot_r > 0) (c_r / tot_r) * 100 else 0
pct_2 <- if(tot_2 > 0) (c_2 / tot_2) * 100 else 0
# Lógica para que muestre "0" a secas si no hay casos (como en tu otra tabla)
str_r <- if(c_r == 0) "0" else paste0(c_r, " (", fmt_pct(pct_r), "%)")
str_2 <- if(c_2 == 0) "0" else paste0(c_2, " (", fmt_pct(pct_2), "%)")
tibble(V = paste0("•   ", label), R = str_r, Y = str_2)
}
# 3. Función continua
calc_cont <- function(var_col, label) {
x_r <- as.numeric(as.character(df[[var_col]][is_retra])) %>% na.omit()
x_2 <- as.numeric(as.character(df[[var_col]][is_25])) %>% na.omit()
fmt <- function(v) gsub("\\.", ",", sprintf("%.1f", v))
l1 <- paste0(fmt(mean(x_r)), " (DE ", fmt(sd(x_r)), ")")
l2 <- paste0(round(median(x_r)), " (IQR ", round(quantile(x_r, 0.25)), "-", round(quantile(x_r, 0.75)), ")")
l1_2 <- paste0(fmt(mean(x_2)), " (DE ", fmt(sd(x_2)), ")")
l2_2 <- paste0(round(median(x_2)), " (IQR ", round(quantile(x_2, 0.25)), "-", round(quantile(x_2, 0.75)), ")")
tibble(V = paste0("**", label, "**"),
R = paste0(l1, "<br>", l2),
Y = paste0(l1_2, "<br>", l2_2))
}
# 4. Ensamblado de la tabla
tabla_recursos_full <- bind_rows(
# Transfusión (USAMOS LA NUEVA VARIABLE CREADA)
tibble(V = "**Transfusión de hemoderivados (primeras 24 horas)**", R = "", Y = ""),
calc_cat("transf_dico", "no", "No"),
calc_cat("transf_dico", "si", "Si"),
# Ventilación mecánica
tibble(V = "**Ventilación mecánica**", R = "", Y = ""),
calc_cat("vmec_dico", "no", "No"),
calc_cat("vmec_dico", "si", "Si"),
calc_cont("vmec_dias", "Dias de VM (días)"),
# Traqueotomía (USAMOS LA NUEVA VARIABLE CREADA)
tibble(V = "**TRAQUEOTOMÍA**", R = "", Y = ""),
calc_cat("traqueo_dico", "no", "No"),
calc_cat("traqueo_dico", "si", "Si"),
# Arteriografía
tibble(V = "**Arteriografia**", R = "", Y = ""),
calc_cat("arteriografia", "no", "No"),
calc_cat("arteriografia", "si diagnostica", "Sí diagnóstica"),
calc_cat("arteriografia", "si terapeutica", "Sí Terapéutica"),
# Terapia renal
tibble(V = "**Terapia renal (TRRC)**", R = "", Y = ""),
calc_cat("terapia_renal", "no", "No"),
calc_cat("terapia_renal", "si", "Si")
)
# Renderizado final
