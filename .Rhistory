calc_cat("fallo_renal", "injury (injuria)", "Injuria"),
calc_cat("fallo_renal", "failure (fallo)", "Fallo"),
calc_cat("fallo_renal", "loss (perdida)", "Pérdida"),
calc_cat("fallo_renal", "eskd (ira)", "ESKD (IRA)"),
# Hemorragia masiva
tibble(V = "**Hemorragia masiva**", R = "", Y = ""),
calc_cat("hemorragia_masiva", "no", "No"),
calc_cat("hemorragia_masiva", "si", "Si"),
# Coagulopatía trauma
tibble(V = "**Coagulopatia trauma**", R = "", Y = ""),
calc_cat("coagulopatia", "no", "No"),
calc_cat("coagulopatia", "si", "Si"),
# SDMO
tibble(V = "**Sindrome de disfunción multiorgánica (S.D.M.O)**", R = "", Y = ""),
calc_cat("sdmo", "sdmo precoz", "**Precoz:** primeras 72 horas."),
calc_cat("sdmo", "sdmo tardio", "**Tardío:** más de 72 horas."),
# Hipertensión endocraneal
tibble(V = "**Hipertensión endocraneal**", R = "", Y = ""),
calc_cat("hec", "si, precisa medidas de 1º nivel", "Medidas primer nivel"),
calc_cat("hec", "si, precisa medidas de 2º nivel", "Medidas segundo nivel"),
# Rabdomiólisis
tibble(V = "**Rabdomiolisis**", R = "", Y = ""),
calc_cat("rabdomiolisis", "no", "No"),
calc_cat("rabdomiolisis", "si", "Si"),
# Infección nosocomial
tibble(V = "**Infección nosocomial**", R = "", Y = ""),
calc_cat("infeccion_nosocomial", "no", "No"),
calc_cat("infeccion_nosocomial", "si", "Si")
)
# Renderizado final
knitr::kable(tabla_complicaciones, col.names = c("", "RETRAUCI", "2025"), align = "lll", escape = FALSE)
is_25 <- (!is.na(df$year) & df$year == "2025")
is_retra <- (!is.na(df$year) & df$year != "2025")
fmt_pct <- function(p) {
val <- sprintf("%.1f", p)
val <- gsub("\\.", ",", val)
val <- sub(",0$", "", val)
return(val)
}
calc_cat <- function(var_col, cat_val, label) {
col_data <- as.character(df[[var_col]])
cat_val_char <- as.character(cat_val)
tot_r <- sum(!is.na(col_data) & trimws(col_data) != "" & is_retra)
tot_2 <- sum(!is.na(col_data) & trimws(col_data) != "" & is_25)
c_r <- sum(col_data == cat_val_char & is_retra, na.rm = TRUE)
c_2 <- sum(col_data == cat_val_char & is_25, na.rm = TRUE)
pct_r <- if(tot_r > 0) (c_r / tot_r) * 100 else 0
pct_2 <- if(tot_2 > 0) (c_2 / tot_2) * 100 else 0
str_r <- if(c_r == 0) "0" else paste0(c_r, " (", fmt_pct(pct_r), "%)")
str_2 <- if(c_2 == 0) "0" else paste0(c_2, " (", fmt_pct(pct_2), "%)")
tibble(V = paste0("•   ", label), R = str_r, Y = str_2)
}
tabla_complicaciones <- bind_rows(
tibble(V = "", R = as.character(sum(is_retra)), Y = as.character(sum(is_25))),
# Hemodinámica
tibble(V = "**Hemodinámica**", R = "", Y = ""),
calc_cat("situacion_hemodinamica", "estable", "Estable"),
calc_cat("situacion_hemodinamica", "inestable remonta con volumen", "Inestable remonta con volumen"),
calc_cat("situacion_hemodinamica", "shock", "Shock"),
calc_cat("situacion_hemodinamica", "shock refractario", "Shock refractario"),
# Respiratoria
tibble(V = "**Respiratoria (pO2/FiO2)**", R = "", Y = ""),
calc_cat("adrs", "no", "No"),
calc_cat("adrs", "> 300", ">300"),
calc_cat("adrs", "201 -300", ">201-300"),
calc_cat("adrs", "101-200", "101-200"),
calc_cat("adrs", "<100", "<100"),
# Renal
tibble(V = "**Renal**", R = "", Y = ""),
calc_cat("fallo_renal", "no", "No"),
calc_cat("fallo_renal", "risk (riesgo)", "Riesgo"),
calc_cat("fallo_renal", "injury (injuria)", "Injuria"),
calc_cat("fallo_renal", "failure (fallo)", "Fallo"),
calc_cat("fallo_renal", "loss (perdida)", "Pérdida"),
calc_cat("fallo_renal", "eskd (ira)", "ESKD (IRA)"),
# Hemorragia masiva
tibble(V = "**Hemorragia masiva**", R = "", Y = ""),
calc_cat("hemorragia_masiva", "no", "No"),
calc_cat("hemorragia_masiva", "si", "Si"),
# Coagulopatía trauma
tibble(V = "**Coagulopatia trauma**", R = "", Y = ""),
calc_cat("coagulopatia", "no", "No"),
calc_cat("coagulopatia", "si", "Si"),
# SDMO
tibble(V = "**Sindrome de disfunción multiorgánica (S.D.M.O)**", R = "", Y = ""),
calc_cat("sdmo", "sdmo precoz", "**Precoz:** primeras 72 horas."),
calc_cat("sdmo", "sdmo tardio", "**Tardío:** más de 72 horas."),
# Hipertensión endocraneal
tibble(V = "**Hipertensión endocraneal**", R = "", Y = ""),
calc_cat("hec", "si, precisa medidas de 1º nivel", "Medidas primer nivel"),
calc_cat("hec", "si, precisa medidas de 2º nivel", "Medidas segundo nivel"),
# Rabdomiólisis
tibble(V = "**Rabdomiolisis**", R = "", Y = ""),
calc_cat("rabdomiolisis", "no", "No"),
calc_cat("rabdomiolisis", "si", "Si"),
# Infección nosocomial
tibble(V = "**Infección nosocomial**", R = "", Y = ""),
calc_cat("infeccion_nosocomial", "no", "No"),
calc_cat("infeccion_nosocomial", "si", "Si")
)
knitr::kable(tabla_complicaciones, col.names = c("", "RETRAUCI", "2025"), align = "lll", escape = FALSE)
df_time <- df %>%
mutate(
iss_num = suppressWarnings(as.numeric(as.character(iss))),
trauma_dt = as.POSIXct(paste(fecha_trauma, hora_trauma), format="%d/%m/%Y %H:%M"),
uci_dt = as.POSIXct(paste(fecha_ingreso_uci, hora_ingreso_uci), format="%d/%m/%Y %H:%M"),
time_to_uci = as.numeric(difftime(uci_dt, trauma_dt, units = "mins"))
) %>%
filter(
iss_num >= 15,
time_to_uci >= 5 & time_to_uci <= 240,
!is.na(year)
)
ggplot(df_time, aes(x = as.factor(year), y = time_to_uci)) +
geom_boxplot(
fill = "#5b9bd5",
color = "black",
width = 0.4,
outlier.shape = NA
) +
labs(
x = NULL,
y = "Tiempo Trauma--> UCI (min)"
) +
theme_classic() +
theme(
axis.text.x = element_text(size = 10),
axis.title.y = element_text(size = 10, face = "bold")
)
