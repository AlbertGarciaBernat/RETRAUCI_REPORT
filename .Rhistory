# Evolución hospitalaria
tibble(V = "**Evolución hospitalaria**", R = "", Y = ""),
calc_cat("evolucion_hospitalaria", "Alta", "Alta"),
calc_cat("evolucion_hospitalaria", "Exitus", "Éxitus"), # Ojo a la tilde en el label
# Destino alta hospitalaria
tibble(V = "**Destino alta hospitalaria**", R = "", Y = ""),
calc_cat("destino_alta_hospitalaria", "Domicilio", "Domicilio"),
calc_cat("destino_alta_hospitalaria", "Traslado a otra UCI", "Traslado a otra UCI"),
calc_cat("destino_alta_hospitalaria", "Hospital de rehabilitación", "Hospital de rehabilitación"),
calc_cat("destino_alta_hospitalaria", "Hospital de origen", "Hospital de origen"),
calc_cat("destino_alta_hospitalaria", "Hospital de referencia de trauma", "Hospital de referencia de trauma"),
# Motivo exitus
tibble(V = "**Motivo éxitus**", R = "", Y = ""),
calc_cat("mot_exitus", "Exanguinación", "Exanguinación"),
calc_cat("mot_exitus", "HEC", "HEC"),
calc_cat("mot_exitus", "SDMO", "SDMO"),
calc_cat("mot_exitus", "Otros", "Otros"),
# Limitación esfuerzo terapéutico
tibble(V = "**Limitación esfuerzo terapéutico**", R = "", Y = ""),
calc_cat("let", "No", "No"),
calc_cat("let", "Si", "Si"),
# Donación (Al ser una fila única sin viñeta, le quitamos el prefijo.
# Asumo que se extrae contando los "Exitus y donación" de evolución_uci)
calc_cat("evolucion_uci", "Exitus y donación", "**Donación**", prefix = ""),
# Estancia UCI (días)
calc_cont("dias_uci", "Estancia UCI (días)"),
# Reingreso en UCI
tibble(V = "**Reingreso en UCI**", R = "", Y = ""),
calc_cat("reingreso", 0, "No"), # Suponiendo que sea 0/1. Si es texto, cambia a "No" / "Si"
calc_cat("reingreso", 1, "Si")
)
# Renderizado final
